# SQLite: caminho relativo à pasta prisma/ → arquivo real prisma/dev.db
DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Admin simples (primeira versão)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="troque-esta-senha"

# Token simples para rotas admin (opcional). Se preenchido, APIs exigem:
# Authorization: Bearer <ADMIN_API_TOKEN>
ADMIN_API_TOKEN=""

# Cloudflare R2 (upload de imagens no admin — API S3-compatible)
# Crie em: Cloudflare Dashboard → R2 → Manage R2 API Tokens (Access Key + Secret).
# Não use o token global (Authorization Bearer) da API REST v4 da Cloudflare aqui.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Opcional: URL pública direta (r2.dev / domínio). Se vazio, imagens são servidas por /api/storage/... (bucket pode ficar privado).
R2_PUBLIC_BASE_URL=""

